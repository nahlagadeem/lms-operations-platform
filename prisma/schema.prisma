generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ActiveStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum DeliveryType {
  TRAINING
  CERTIFICATION
  LANGUAGE
  CONFERENCE
  WORKSHOP
}

enum DeliveryMode {
  IN_PERSON
  ONLINE
  HYBRID
  ABROAD
}

enum ProviderType {
  TRAINING_CENTER
  UNIVERSITY
  CERTIFICATION_BODY
  CONFERENCE_ORGANIZER
  VENDOR
}

enum LocationType {
  INTERNAL_VENUE
  EXTERNAL_VENUE
  ONLINE
  INTERNATIONAL
}

enum CourseRunStatus {
  DRAFT
  PLANNED
  APPROVAL_PENDING
  OPEN_FOR_NOMINATION
  CONFIRMED
  ONGOING
  COMPLETED
  CANCELED
  POSTPONED
  CLOSED
}

enum ApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum CourseCardStatus {
  NOT_STARTED
  DRAFT
  SUBMITTED
  APPROVED
}

enum ParticipantType {
  STUDENT
  TEACHER
  OWNER
  COORDINATOR
  OBSERVER
}

enum NominationStatus {
  NOMINATED
  CONTACTED
  CONFIRMED
  DECLINED
  REPLACED
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  PARTIAL
}

enum ReportStatus {
  PENDING
  DRAFT
  SUBMITTED
  APPROVED
}

enum FinalProjectReportType {
  PACKAGE_SUMMARY
  MONTHLY_OPERATIONS
  LEADERSHIP_TRACK_SUMMARY
  FINAL_PROJECT_REPORT
}

enum UserRole {
  SUPER_ADMIN
  PROJECT_MANAGER
  OPERATIONS_COORDINATOR
  REPORTING_ANALYST
  VIEWER
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum TrainingCity {
  RIYADH
  JEDDAH
  DAMMAM
  KHOBAR
  MAKKAH
  MADINAH
  TAIF
  ABHA
  TABUK
  HAIL
  JUBAIL
  NAJRAN
  YANBU
}

enum DocumentType {
  COURSE_CARD
  PRESENTATION
  LEARNER_GUIDE
  ATTENDANCE_SHEET
  CERTIFICATE_TEMPLATE
  QUALITY_REPORT
  FINAL_REPORT
  PHOTOS_ARCHIVE
  OTHER
}

enum DocumentEntityType {
  FRAMEWORK_AGREEMENT
  SCOPE
  PACKAGE
  COURSE
  COURSE_RUN
  PROVIDER
  TRAINER
  PARTICIPANT
  LOCATION
  APPROVAL
  INVOICE
  RISK
  ISSUE
  REPORT
}

enum ProjectActivityType {
  PREVIOUS
  CURRENT
  UPCOMING
}

model ProjectSummary {
  id                     String    @id @default(cuid())
  singletonKey           String    @unique @default("ACTIVE")
  startDate              DateTime?
  expectedEndDate        DateTime?
  baselineProgress       Decimal   @default(0) @db.Decimal(5, 2)
  actualProgress         Decimal   @default(0) @db.Decimal(5, 2)
  totalProjectValue      Decimal   @default(0) @db.Decimal(18, 2)
  totalProjectInvoices   Decimal   @default(0) @db.Decimal(18, 2)
  totalCollectedValue    Decimal   @default(0) @db.Decimal(18, 2)
  remainingUnbilledValue Decimal   @default(0) @db.Decimal(18, 2)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model ProjectActivity {
  id        String              @id @default(cuid())
  type      ProjectActivityType
  text      String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([type, createdAt])
}

model ProjectRisk {
  id           String    @id @default(cuid())
  description  String
  date         DateTime?
  impact       String
  probability  String
  owner        String
  responsePlan String
  status       String
  closureDate  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ProjectIssue {
  id           String    @id @default(cuid())
  description  String
  date         DateTime?
  owner        String
  responsePlan String
  status       String
  closureDate  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Package {
  id                    String        @id @default(cuid())
  scopeId               String?
  code                  String        @unique
  nameAr                String
  nameEn                String?
  description           String?
  expectedTraineeCount  Int?
  originalTotalAmount   Decimal?      @db.Decimal(18, 2)
  discountedTotalAmount Decimal?      @db.Decimal(18, 2)
  isActive              Boolean       @default(true)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  scope                 ProjectScope? @relation(fields: [scopeId], references: [id], onDelete: SetNull)
  courses               Course[]

  @@index([scopeId])
}

model ProjectScope {
  id                String               @id @default(cuid())
  code              String               @unique
  name              String
  nameAr            String?
  nameEn            String?
  description       String?
  region            String?
  startDate         DateTime?
  expectedEndDate   DateTime?
  notes             String?
  plannedCompletion Decimal?             @db.Decimal(5, 2)
  actualCompletion  Decimal?             @db.Decimal(5, 2)
  budgetAmount      Decimal?             @db.Decimal(18, 2)
  invoicedAmount    Decimal?             @db.Decimal(18, 2)
  collectedAmount   Decimal?             @db.Decimal(18, 2)
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  packages          Package[]
  selectedCourses   ProjectScopeCourse[]
  courseRuns        CourseRun[]
}

model CourseCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  nameAr      String
  nameEn      String?
  description String?
  courses     Course[]
}

model Course {
  id                           String               @id @default(cuid())
  packageId                    String
  categoryId                   String
  courseCode                   String               @unique
  nameAr                       String
  nameEn                       String?
  description                  String?
  deliveryType                 DeliveryType
  unitOfMeasure                String?
  defaultDurationDays          Int?
  defaultDurationHours         Int?
  language                     String?
  isExternal                   Boolean              @default(false)
  requiresCertificate          Boolean              @default(false)
  requiresProviderRegistration Boolean              @default(false)
  activeStatus                 ActiveStatus         @default(ACTIVE)
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt
  package                      Package              @relation(fields: [packageId], references: [id], onDelete: Restrict)
  category                     CourseCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  pricingRecords               CoursePricing[]
  runs                         CourseRun[]
  scopeSelections              ProjectScopeCourse[]
}

model ProjectScopeCourse {
  id             String       @id @default(cuid())
  scopeId        String
  courseId       String
  sortOrder      Int
  estimatedSeats Int?
  createdAt      DateTime     @default(now())
  scope          ProjectScope @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseRuns     CourseRun[]

  @@unique([scopeId, courseId])
  @@index([scopeId, sortOrder])
  @@index([courseId])
}

model CoursePricing {
  id                          String    @id @default(cuid())
  courseId                    String
  originalUnitPriceWithTax    Decimal?  @db.Decimal(18, 2)
  originalUnitPriceWithoutTax Decimal?  @db.Decimal(18, 2)
  discountPercentage          Decimal?  @db.Decimal(5, 4)
  discountAmount              Decimal?  @db.Decimal(18, 2)
  finalUnitPriceWithoutTax    Decimal?  @db.Decimal(18, 2)
  currencyCode                String    @default("SAR")
  effectiveFrom               DateTime?
  effectiveTo                 DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  course                      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Provider {
  id            String       @id @default(cuid())
  providerType  ProviderType
  nameAr        String
  nameEn        String?
  country       String?
  city          String?
  contactPerson String?
  email         String?
  phone         String?
  website       String?
  isActive      Boolean      @default(true)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  trainers      Trainer[]
  courseRuns    CourseRun[]
}

model Trainer {
  id                String              @id @default(cuid())
  providerId        String?
  fullNameAr        String
  fullNameEn        String?
  email             String?
  phone             String?
  nationality       String?
  yearsOfExperience Int?
  isApproved        Boolean             @default(false)
  approvalDate      DateTime?
  bio               String?
  specialization    String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  provider          Provider?           @relation(fields: [providerId], references: [id], onDelete: SetNull)
  credentials       TrainerCredential[]
  courseAssignments CourseRunTrainer[]
}

model TrainerCredential {
  id                 String             @id @default(cuid())
  trainerId          String
  credentialName     String
  issuingBody        String?
  credentialType     String?
  issueDate          DateTime?
  expiryDate         DateTime?
  documentUrl        String?
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  trainer            Trainer            @relation(fields: [trainerId], references: [id], onDelete: Cascade)
}

model Location {
  id           String       @id @default(cuid())
  locationType LocationType
  nameAr       String
  nameEn       String?
  country      String?
  city         String?
  branch       String?
  venueName    String?
  roomName     String?
  address      String?
  mapUrl       String?
  timezone     String?
  capacity     Int?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  courseRuns   CourseRun[]
}

model CourseRun {
  id                   String              @id @default(cuid())
  courseId             String
  projectScopeId       String?
  projectScopeCourseId String?
  providerId           String?
  locationId           String?
  vendorCost           Decimal?            @db.Decimal(18, 2)
  daysHeld             Int?
  city                 TrainingCity?
  runCode              String              @unique
  status               CourseRunStatus     @default(DRAFT)
  deliveryMode         DeliveryMode
  startDate            DateTime?
  endDate              DateTime?
  startTime            String?
  endTime              String?
  plannedSeats         Int?
  confirmedSeats       Int                 @default(0)
  attendanceRequired   Boolean             @default(true)
  certificateRequired  Boolean             @default(false)
  courseCardStatus     CourseCardStatus    @default(NOT_STARTED)
  approvalStatus       ApprovalStatus      @default(PENDING)
  rescheduleCount      Int                 @default(0)
  ownerUserId          String?
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  course               Course              @relation(fields: [courseId], references: [id], onDelete: Restrict)
  projectScope         ProjectScope?       @relation(fields: [projectScopeId], references: [id], onDelete: SetNull)
  projectScopeCourse   ProjectScopeCourse? @relation(fields: [projectScopeCourseId], references: [id], onDelete: SetNull)
  provider             Provider?           @relation(fields: [providerId], references: [id], onDelete: SetNull)
  location             Location?           @relation(fields: [locationId], references: [id], onDelete: SetNull)
  ownerUser            AppUser?            @relation("OwnedCourseRuns", fields: [ownerUserId], references: [id], onDelete: SetNull)
  trainers             CourseRunTrainer[]
  documents            CourseRunDocument[]
  nominations          Nomination[]
  attendanceRecords    AttendanceRecord[]
  evaluations          Evaluation[]
  qualityReports       QualityReport[]

  @@index([projectScopeId])
  @@index([projectScopeCourseId])
}

model CourseRunTrainer {
  id          String    @id @default(cuid())
  courseRunId String
  trainerId   String
  role        String?
  isPrimary   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  courseRun   CourseRun @relation(fields: [courseRunId], references: [id], onDelete: Cascade)
  trainer     Trainer   @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([courseRunId, trainerId])
}

model CourseRunDocument {
  id               String       @id @default(cuid())
  courseRunId      String
  documentType     DocumentType
  fileName         String
  originalFileName String?
  fileUrl          String
  storagePath      String?
  mimeType         String?
  fileSizeBytes    Int?
  version          Int          @default(1)
  uploadedByUserId String?
  uploadedAt       DateTime     @default(now())
  notes            String?
  courseRun        CourseRun    @relation(fields: [courseRunId], references: [id], onDelete: Cascade)
  uploadedByUser   AppUser?     @relation("UploadedDocuments", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([courseRunId, documentType])
}

model Document {
  id               String             @id @default(cuid())
  entityType       DocumentEntityType
  entityId         String
  documentType     DocumentType
  title            String?
  fileName         String
  originalFileName String?
  fileUrl          String
  storagePath      String?
  mimeType         String?
  fileSizeBytes    Int?
  version          Int                @default(1)
  contextLabel     String?
  uploadedByUserId String?
  uploadedAt       DateTime           @default(now())
  notes            String?
  uploadedByUser   AppUser?           @relation("UploadedGlobalDocuments", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([entityType, entityId, documentType])
}

model Participant {
  id                String             @id @default(cuid())
  participantType   ParticipantType
  nationalIdOrIqama String?
  employeeNumber    String?
  fullNameAr        String
  fullNameEn        String?
  email             String?
  phone             String?
  organizationName  String?
  jobTitle          String?
  department        String?
  city              String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  nominations       Nomination[]
  attendanceRecords AttendanceRecord[]
  evaluations       Evaluation[]

  @@unique([participantType, nationalIdOrIqama])
}

model Nomination {
  id                         String            @id @default(cuid())
  courseRunId                String
  participantId              String
  nominationStatus           NominationStatus  @default(NOMINATED)
  nominatedByUserId          String?
  nominatedAt                DateTime          @default(now())
  confirmationStatus         NominationStatus?
  confirmedAt                DateTime?
  declineReason              String?
  replacementForNominationId String?
  notes                      String?
  courseRun                  CourseRun         @relation(fields: [courseRunId], references: [id], onDelete: Cascade)
  participant                Participant       @relation(fields: [participantId], references: [id], onDelete: Cascade)
  nominatedByUser            AppUser?          @relation("NominatedParticipants", fields: [nominatedByUserId], references: [id], onDelete: SetNull)
  replacementFor             Nomination?       @relation("NominationReplacement", fields: [replacementForNominationId], references: [id], onDelete: SetNull)
  replacements               Nomination[]      @relation("NominationReplacement")

  @@unique([courseRunId, participantId])
}

model AttendanceRecord {
  id               String           @id @default(cuid())
  courseRunId      String
  participantId    String
  attendanceDate   DateTime
  checkInTime      DateTime?
  checkOutTime     DateTime?
  attendanceStatus AttendanceStatus
  notes            String?
  recordedByUserId String?
  recordedAt       DateTime         @default(now())
  courseRun        CourseRun        @relation(fields: [courseRunId], references: [id], onDelete: Cascade)
  participant      Participant      @relation(fields: [participantId], references: [id], onDelete: Cascade)
  recordedByUser   AppUser?         @relation("RecordedAttendance", fields: [recordedByUserId], references: [id], onDelete: SetNull)

  @@unique([courseRunId, participantId, attendanceDate])
}

model Evaluation {
  id               String      @id @default(cuid())
  courseRunId      String
  participantId    String
  trainerScore     Int?
  venueScore       Int?
  contentScore     Int?
  operationsScore  Int?
  overallScore     Decimal?    @db.Decimal(5, 2)
  positiveNotes    String?
  improvementNotes String?
  submittedAt      DateTime    @default(now())
  courseRun        CourseRun   @relation(fields: [courseRunId], references: [id], onDelete: Cascade)
  participant      Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([courseRunId, participantId])
}

model QualityReport {
  id                String       @id @default(cuid())
  courseRunId       String
  reportStatus      ReportStatus @default(PENDING)
  submittedByUserId String?
  submittedAt       DateTime?
  dueDate           DateTime?
  summary           String?
  satisfactionRate  Decimal?     @db.Decimal(5, 2)
  issuesFound       String?
  actionsTaken      String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  courseRun         CourseRun    @relation(fields: [courseRunId], references: [id], onDelete: Cascade)
  submittedByUser   AppUser?     @relation("SubmittedQualityReports", fields: [submittedByUserId], references: [id], onDelete: SetNull)
}

model FinalProjectReport {
  id                String                 @id @default(cuid())
  reportType        FinalProjectReportType
  periodStart       DateTime?
  periodEnd         DateTime?
  generatedByUserId String?
  generatedAt       DateTime               @default(now())
  summary           String?
  fileUrl           String?
  generatedByUser   AppUser?               @relation("GeneratedFinalReports", fields: [generatedByUserId], references: [id], onDelete: SetNull)
}

model AppUser {
  id                      String               @id @default(cuid())
  fullName                String
  email                   String               @unique
  role                    UserRole
  department              String?
  isActive                Boolean              @default(true)
  lastLoginAt             DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  ownedCourseRuns         CourseRun[]          @relation("OwnedCourseRuns")
  uploadedDocuments       CourseRunDocument[]  @relation("UploadedDocuments")
  uploadedGlobalDocuments Document[]           @relation("UploadedGlobalDocuments")
  nominatedParticipants   Nomination[]         @relation("NominatedParticipants")
  recordedAttendance      AttendanceRecord[]   @relation("RecordedAttendance")
  submittedQualityReports QualityReport[]      @relation("SubmittedQualityReports")
  generatedFinalReports   FinalProjectReport[] @relation("GeneratedFinalReports")
  auditLogs               AuditLog[]
}

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  entityType    String
  entityId      String
  actionType    String
  oldValuesJson Json?
  newValuesJson Json?
  createdAt     DateTime @default(now())
  actorUser     AppUser? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
}
